@page
@model money_management.Pages.Budgets.IndexModel
@using Microsoft.AspNetCore.Mvc.Rendering

<h2>Quản lý ngân sách</h2>

<button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#addModal">+ Thêm ngân sách</button>

<table class="table table-hover table-bordered text-center align-middle">
    <thead class="table-dark">
        <tr>
            <th class="text-start">Danh mục</th>
            <th>Tháng</th>
            <th>Năm</th>
            <th>Số tiền</th>
            <th style="width: 100px;">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Budgets)
        {
                <tr>
                    <td class="text-start">@item.Category?.Name</td>
                    <td>@item.Month</td>
                    <td>@item.Year</td>
                    <td class="text-success fw-bold">@item.Amount.ToString("N0") đ</td>
                    <td>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline">
                            <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn có chắc muốn xóa?')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
        }
    </tbody>
</table>



<!-- Modal Thêm -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Add">
                <div class="modal-header">
                    <h5 class="modal-title">Thêm ngân sách</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="NewBudget.CategoryId" class="form-label">Danh mục</label>
                        <select asp-for="NewBudget.CategoryId" asp-items="Model.Categories" class="form-select"></select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewBudget.Month" class="form-label">Tháng</label>
                        <input asp-for="NewBudget.Month" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewBudget.Year" class="form-label">Năm</label>
                        <input asp-for="NewBudget.Year" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewBudget.Amount" class="form-label">Số tiền</label>
                        <input asp-for="NewBudget.Amount" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Lưu</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                </div>
            </form>
        </div>
    </div>
</div>
