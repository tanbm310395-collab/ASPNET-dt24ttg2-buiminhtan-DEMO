@page
@model money_management.Pages.Transactions.IndexModel
@using Microsoft.AspNetCore.Mvc.Rendering
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<h2 class="mb-4">Quản lý giao dịch</h2>

<!-- Nút Thêm -->
<button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#addModal">
    <i class="bi bi-plus-circle"></i> Thêm giao dịch
</button>

<!-- Bảng danh sách -->
<table class="table table-striped table-hover align-middle shadow-sm rounded">
    <thead class="table-dark">
        <tr>
            <th class="text-center align-middle">Danh mục</th>
            <th class="text-center align-middle">Số tiền</th>
            <th class="text-center align-middle">Ghi chú</th>
            <th class="text-center align-middle">Ngày</th>
            <th class="text-center align-middle">Hóa đơn</th>
            <th class="text-center align-middle">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in Model.Transactions)
        {
            <tr>
                <td class="align-middle">@t.Category?.Name</td>
                <td class="text-end text-success fw-semibold align-middle">@t.Amount.ToString("N0") đ</td>
                <td class="align-middle">@t.Note</td>
                <td class="text-center align-middle">@t.Date.ToString("dd/MM/yyyy")</td>
                <td class="text-center align-middle">
                    @if (!string.IsNullOrEmpty(t.ImagePath))
                    {
                        <img src="/uploads/@t.ImagePath" alt="Hóa đơn" width="50" class="rounded border" />
                    }
                    else
                    {
                        <span class="text-muted fst-italic">Không có</span>
                    }
                </td>
                <td class="text-center align-middle">
                    <form method="post" asp-page-handler="Delete" asp-route-id="@t.Id" class="d-inline">
                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn có chắc muốn xóa?')">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                    <button class="btn btn-sm btn-outline-warning ms-1" data-bs-toggle="modal" data-bs-target="#editModal"
                            onclick="fillEdit('@t.Id', '@t.CategoryId', '@t.Amount', '@t.Note', '@t.Date.ToString("yyyy-MM-dd")')">
                        <i class="bi bi-pencil-square"></i>
                    </button>
                </td>
            </tr>
        }
    </tbody>

</table>


<!-- Modal Thêm -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" enctype="multipart/form-data" asp-page-handler="Add">
                <div class="modal-header">
                    <h5 class="modal-title">Thêm giao dịch</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="NewTransaction.CategoryId" class="form-label">Danh mục</label>
                        <select asp-for="NewTransaction.CategoryId" asp-items="Model.CategoryOptions" class="form-select"></select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewTransaction.Amount" class="form-label">Số tiền</label>
                        <input asp-for="NewTransaction.Amount" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewTransaction.Note" class="form-label">Ghi chú</label>
                        <input asp-for="NewTransaction.Note" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="NewTransaction.Date" class="form-label">Ngày</label>
                        <input asp-for="NewTransaction.Date" type="date" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hình ảnh</label>
                        <input type="file" name="ImageFile" class="form-control" accept=".jpg,.jpeg,.png,.gif" />
                    </div>


                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Lưu</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Sửa -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Edit">
                <div class="modal-header">
                    <h5 class="modal-title">Sửa giao dịch</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="EditTransaction.Id" id="edit-id" />
                    <div class="mb-3">
                        <label asp-for="EditTransaction.CategoryId" class="form-label">Danh mục</label>
                        <select asp-for="EditTransaction.CategoryId" asp-items="Model.CategoryOptions" id="edit-category" class="form-select"></select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="EditTransaction.Amount" class="form-label">Số tiền</label>
                        <input asp-for="EditTransaction.Amount" id="edit-amount" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="EditTransaction.Note" class="form-label">Ghi chú</label>
                        <input asp-for="EditTransaction.Note" id="edit-note" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="EditTransaction.Date" class="form-label">Ngày</label>
                        <input asp-for="EditTransaction.Date" id="edit-date" type="date" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hình ảnh</label>
                        <input type="file" name="ImageFile" class="form-control" accept=".jpg,.jpeg,.png,.gif" />
                    </div>

                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Cập nhật</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function fillEdit(id, categoryId, amount, note, date) {
            document.getElementById("edit-id").value = id;
            document.getElementById("edit-category").value = categoryId;
            document.getElementById("edit-amount").value = amount;
            document.getElementById("edit-note").value = note;
            document.getElementById("edit-date").value = date;
        }
    </script>
}
