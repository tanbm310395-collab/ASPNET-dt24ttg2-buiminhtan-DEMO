@page
@model RegisterModel

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Đăng ký</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container d-flex justify-content-center align-items-center vh-100">
        <div class="card shadow p-4" style="width: 100%; max-width: 450px;">
            <h3 class="text-center mb-4">Đăng ký tài khoản</h3>
            <form method="post">
                <div asp-validation-summary="All" class="text-danger"></div>
                <div class="mb-3">
                    <input asp-for="User.FirstName" class="form-control" placeholder="Họ" />
                </div>
                <div class="mb-3">
                    <input asp-for="User.LastName" class="form-control" placeholder="Tên" />
                </div>
                <div class="mb-3">
                    <input asp-for="User.Email" type="email" class="form-control" placeholder="Email" />
                </div>
                <div class="mb-3">
                    <input asp-for="Password" type="password" class="form-control" placeholder="Mật khẩu" />
                </div>

                <button type="submit" class="btn btn-success w-100">Đăng ký</button>
            </form>
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success mt-3">
                    @TempData["SuccessMessage"]
                </div>
            }
            <div class="text-center mt-3">
                <small>Đã có tài khoản? <a asp-page="/Login">Đăng nhập</a></small>
            </div>

        </div>
    </div>
</body>
</html>
