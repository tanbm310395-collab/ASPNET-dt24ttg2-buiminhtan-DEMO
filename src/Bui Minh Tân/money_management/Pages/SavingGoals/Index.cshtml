@page
@model money_management.Pages.SavingGoals.IndexModel
@{
    ViewData["Title"] = "Quản lý mục tiêu tiết kiệm";
}

<h2 class="mb-4">Quản lý mục tiêu tiết kiệm</h2>

<button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#addModal">+ Thêm mục tiêu</button>

<table class="table table-hover table-bordered text-center align-middle">
    <thead class="table-dark">
        <tr>
            <th>Tên</th>
            <th>Mục tiêu</th>
            <th>Hiện tại</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var g in Model.Goals)
        {
            <tr>
                <td class="text-start">@g.Title</td>
                <td class="text-end text-primary fw-semibold">@g.TargetAmount.ToString("N0") đ</td>
                <td class="text-end text-success fw-semibold">@g.CurrentAmount.ToString("N0") đ</td>
                <td>
                    <button class="btn btn-sm btn-outline-warning me-1" data-bs-toggle="modal" data-bs-target="#editModal-@g.Id">
                        <i class="bi bi-pencil-square"></i>
                    </button>
                    <form method="post" asp-page-handler="Delete" class="d-inline">
                        <input type="hidden" name="id" value="@g.Id" />
                        <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn có chắc muốn xóa?')">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>

                    <!-- Modal Edit -->
                    <div class="modal fade" id="editModal-@g.Id" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <form method="post" asp-page-handler="Edit">
                                    <div class="modal-header">
                                        <h5 class="modal-title">Cập nhật mục tiêu</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body">
                                        <input type="hidden" asp-for="Goal.Id" value="@g.Id" />

                                        <div class="mb-3">
                                            <label asp-for="Goal.Title" class="form-label">Tên</label>
                                            <input asp-for="Goal.Title" value="@g.Title" class="form-control" name="Goal.Name" />
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="Goal.TargetAmount" class="form-label">Mục tiêu</label>
                                            <input asp-for="Goal.TargetAmount" value="@g.TargetAmount" class="form-control" name="Goal.TargetAmount" />
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="Goal.CurrentAmount" class="form-label">Hiện tại</label>
                                            <input asp-for="Goal.CurrentAmount" value="@g.CurrentAmount" class="form-control" name="Goal.CurrentAmount" />
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="submit" class="btn btn-success">Lưu</button>
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>


<!-- Modal Add -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Add">
                <div class="modal-header">
                    <h5 class="modal-title">Thêm mục tiêu</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="NewGoal.Title" class="form-label">Tên</label>
                        <input asp-for="NewGoal.Title" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewGoal.TargetAmount" class="form-label">Mục tiêu</label>
                        <input asp-for="NewGoal.TargetAmount" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewGoal.CurrentAmount" class="form-label">Hiện tại</label>
                        <input asp-for="NewGoal.CurrentAmount" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Thêm</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                </div>
            </form>
        </div>
    </div>
</div>